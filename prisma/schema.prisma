generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["app_auth", "public"]
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  sessions        Session[]
  jobApplications JobApplication[]

  @@map("users")
  @@schema("app_auth")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("app_auth")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("app_auth")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("app_auth")
}

model JobApplication {
  id              String            @id @default(cuid())
  userId          String
  companyName     String
  jobTitle        String
  location        String?
  jobUrl          String?
  source          JobSource         @default(OTHER)
  workMode        WorkMode          @default(ON_SITE)
  salaryMin       Int?
  salaryMax       Int?
  currency        String?           @default("IDR")
  excitementScore Int?
  status          ApplicationStatus @default(APPLIED)
  appliedAt       DateTime          @default(now())
  lastActivityAt  DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  contacts        Contact[]
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes           Note[]
  timelineEvents  TimelineEvent[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, lastActivityAt])
  @@index([userId, appliedAt])
  @@index([userId, excitementScore])
  @@map("job_applications")
  @@schema("public")
}

model TimelineEvent {
  id             String             @id @default(cuid())
  jobAppId       String
  eventType      TimelineEventType  @default(STATUS_CHANGE)
  oldStatus      ApplicationStatus?
  newStatus      ApplicationStatus?
  description    String?
  occurredAt     DateTime           @default(now())
  jobApplication JobApplication     @relation(fields: [jobAppId], references: [id], onDelete: Cascade)

  @@index([jobAppId])
  @@index([jobAppId, occurredAt])
  @@map("timeline_events")
  @@schema("public")
}

model Note {
  id             String         @id @default(cuid())
  jobAppId       String
  content        String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  jobApplication JobApplication @relation(fields: [jobAppId], references: [id], onDelete: Cascade)

  @@index([jobAppId])
  @@map("notes")
  @@schema("public")
}

model Contact {
  id             String         @id @default(cuid())
  jobAppId       String
  name           String
  role           String?
  email          String?
  linkedinUrl    String?
  notes          String?
  createdAt      DateTime       @default(now())
  jobApplication JobApplication @relation(fields: [jobAppId], references: [id], onDelete: Cascade)

  @@index([jobAppId])
  @@map("contacts")
  @@schema("public")
}

model PrefillToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  payload   String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("prefill_tokens")
  @@schema("public")
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
  GHOSTED

  @@schema("public")
}

enum WorkMode {
  REMOTE
  HYBRID
  ON_SITE

  @@schema("public")
}

enum JobSource {
  LINKEDIN
  DEALLS
  KALIBRR
  INDEED
  GLASSDOOR
  COMPANY_WEBSITE
  REFERRAL
  RECRUITER
  JOB_FAIR
  GITHUB_JOBS
  OTHER

  @@schema("public")
}

enum TimelineEventType {
  STATUS_CHANGE
  NOTE_ADDED
  CONTACT_ADDED
  AUTO_GHOSTED
  MANUAL_UPDATE

  @@schema("public")
}
